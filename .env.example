# ThinkTwice — LLM Provider API Keys
# Copy this file to .env and fill in at least one API key.

# ── Option 1: Google Gemini (FREE: 1,500 req/day, 1M tokens/min) ──────────────
# Get your free key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Option 2: Groq (FREE: 14,400 req/day) ─────────────────────────────────────
# Get your free key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# ── Option 3: HuggingFace (FREE: 1,000 req/day) ───────────────────────────────
# Get your free token at: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=your_huggingface_token_here

# ── Provider selection (optional — auto-detected if not set) ──────────────────
# Choices: gemini | groq | huggingface
LLM_PROVIDER=gemini
